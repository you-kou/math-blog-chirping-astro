# Set default behavior to always use LF
* text=auto eol=lf

# Explicitly declare text files to be normalized to LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.css text eol=lf
*.astro text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.svg text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Denote binary files that should not be modified
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
